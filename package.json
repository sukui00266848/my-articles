{
  "name": "article-quality-scripts",
  "version": "1.0.0",
  "description": "Helper scripts: sentence checker, report generator, auto-split suggestions, contrast check",
  "scripts": {
    "check:sentences": "node scripts/sentence-checker.js . 30",
    "gen:image-meta": "node scripts/image-meta-gen.js .",
    "check:contrast": "node scripts/contrast-check.js jiangshan-palettes.example.json",
    "gen:report": "node scripts/generate-sentence-report.js . 30",
    "gen:suggestions": "node scripts/auto-split-suggestions.js ./reports/sentence-report.json . 30"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "chroma-js": "^2.4.2"
  }
}
